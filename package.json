{
  "name": "center-div-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "An interactive CSS centering game that teaches 10 different techniques through progressive levels. Built with React 19, TypeScript, Vite, and Monaco Editor.",
  "keywords": [
    "css",
    "centering",
    "game",
    "interactive",
    "education",
    "learn-css",
    "web-development",
    "react",
    "typescript",
    "vite",
    "monaco-editor",
    "frontend",
    "css-grid",
    "flexbox"
  ],
  "homepage": "https://timothy-y-yuan.github.io/center-div-game",
  "repository": {
    "type": "git",
    "url": "https://github.com/timothy-y-yuan/center-div-game.git"
  },
  "bugs": {
    "url": "https://github.com/timothy-y-yuan/center-div-game/issues"
  },
  "author": {
    "name": "Timothy Yuan",
    "url": "https://github.com/timothy-y-yuan"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-resizable-panels": "^3.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "happy-dom": "^18.0.1",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  }
}
